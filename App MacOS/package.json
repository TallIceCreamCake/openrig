{
  "name": "openrig-desktop",
  "productName": "OpenRIG",
  "version": "0.1.0",
  "description": "Open RIG - Application desktop macOS",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "/usr/libexec/PlistBuddy -c \"Set :CFBundleName OpenRIG\" node_modules/electron/dist/Electron.app/Contents/Info.plist 2>/dev/null; /usr/libexec/PlistBuddy -c \"Set :CFBundleDisplayName OpenRIG\" node_modules/electron/dist/Electron.app/Contents/Info.plist 2>/dev/null; electron .",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.openrig.desktop",
    "productName": "OpenRIG",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "main.js",
      "preload.cjs",
      "onboarding.html",
      "settings.html"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "app",
        "filter": ["**/*"]
      },
      {
        "from": "../server",
        "to": "server",
        "filter": ["**/*", "!data/**"]
      },
      {
        "from": "../node_modules",
        "to": "node_modules",
        "filter": [
          "express/**",
          "body-parser/**",
          "cors/**",
          "nodemailer/**",
          "jszip/**",
          "puppeteer/**",
          "puppeteer-core/**",
          "@supabase/**",
          "otpauth/**",
          "qrcode/**"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "icon": "logo.png",
      "forceCodeSigning": false,
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    }
  }
}
